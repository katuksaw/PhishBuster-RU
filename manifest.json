{
  "manifest_version": 3,
  "name": "PhishBuster RU",
  "version": "1.0.0",
  "description": "Браузерное расширение для выявления фишинговых сайтов на основе анализа цифровых метрик и локальной базы эталонов",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishBuster RU — Анализ безопасности"
  }
}
